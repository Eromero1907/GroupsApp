# ══════════════════════════════════════════════════════════════
#  GroupsApp — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════
#
#  ── Frontend (Next.js) — inyectadas en build; sin prefijo no van al bundle
#  Misma URL pública que usas para el API (NLB / edge), SIN barra final
# NEXT_PUBLIC_API_URL=http://tu-nlb.elb.us-east-1.amazonaws.com
# NEXT_PUBLIC_PRESENCE_WS_URL=http://tu-nlb.elb.us-east-1.amazonaws.com
#

# ── Seguridad ──────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-cambiar-en-prod

# ── Base de datos (PostgreSQL) ─────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=password

# ── AWS S3 (media-service) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ── Entorno ────────────────────────────────────────────────────
NODE_ENV=development

# ══════════════════════════════════════════════════════════════
#  Las siguientes variables tienen defaults funcionales en
#  docker-compose.yml y NO necesitan cambiarse para desarrollo
#  local.
# ══════════════════════════════════════════════════════════════

# AUTH_SERVICE_URL=http://auth-service:3001
# USERS_SERVICE_URL=http://users-service:3002
# GROUPS_SERVICE_URL=http://groups-service:3003
# MEDIA_SERVICE_URL=http://media-service:3004
# MESSAGING_SERVICE_URL=http://messaging-service:3005
# PRESENCE_SERVICE_URL=http://presence-service:3006
# USERS_GRPC_URL=users-service:50052
# GROUPS_GRPC_URL=groups-service:50053
# KAFKA_BROKER=kafka:29092
# En EKS con varios brokers: lista separada por comas (ej. kafka-0...:9092,kafka-1...:9092)
# REDIS_URL=redis://redis:6379
# CONSUL_URL=http://consul:8500